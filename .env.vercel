# Vercel 环境变量配置
# 在 Vercel 项目设置中添加这些环境变量

# 微信支付配置
WECHAT_MCHID=your_wechat_mchid
WECHAT_APIV3_KEY=your_wechat_apiv3_key
WECHAT_CERT_SERIAL_NO=your_cert_serial_no
WECHAT_APPID=your_wechat_appid

# 支付宝配置
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 注意：
# 1. 微信支付证书文件需要通过 Vercel 的 CLI 工具上传
# 2. 或者将证书内容存储为环境变量 WECHAT_PRIVATE_KEY
# 3. 支付回调地址在 Vercel 部署后会自动配置
